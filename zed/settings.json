// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "languages": {
    "TypeScript": {
      "format_on_save": "off",
      "indent_guides": {
        "enabled": true
      },
      "tab_size": 4
    },
    "JavaScript": {
      "tab_size": 4,
      "format_on_save": "off"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "show_edit_predictions": false,
  "edit_predictions": {
    "mode": "subtle",
  },
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "provider": "lmstudio",
      "model": "qwen/qwen3.5-9b",
    },
    "model_parameters": [],
  },
  "disable_ai": false,
  "icon_theme": "Catppuccin Frappé",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Nightfox - blurred",
    "dark": "Duskfox - opaque",
  },
  "auto_install_extensions": {
    "catppuccin-icons": true,
    "discord-presence": false,
    "git-firefly": true,
    "html": true,
    "csv": true,
    "dockerfile": true,
    "rainbow-csv": true,
    "sql": true,
    "nvim-nightfox": true,
  },
}
